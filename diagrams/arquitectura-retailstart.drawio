        <mxCell id="L0" value="Entorno cloud — vista lógica (modelo Lambda adaptado)" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 8;strokeColor=#1ba1e2;fillColor=#f8fafc;fontStyle=1;fontSize=12;" vertex="1" parent="1">
