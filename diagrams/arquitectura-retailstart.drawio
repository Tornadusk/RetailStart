        <mxCell id="L1" value="Fuentes de datos&#xa;Archivos CSV, JSON, XML, TXT&#xa;Carpeta data_sources/ (orígenes dispersos)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
