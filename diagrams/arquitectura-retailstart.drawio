        </mxCell>
        <mxCell id="L3" value="Data Lake (FS) — almacenamiento maestro&#xa;data_lake/raw/ + processed/&#xa;• ELT: carga datos al lake → raw/&#xa;• ETL: escribe processed/ (sigue en el lake)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="380" y="150" width="195" height="155" as="geometry"/>
