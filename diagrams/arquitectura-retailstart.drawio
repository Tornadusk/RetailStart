        <mxCell id="E6" value="evolución (referencia)" style="endArrow=open;dashed=1;html=1;strokeWidth=2;dashPattern=4 4;fontSize=10;fontColor=#666666;labelBackgroundColor=#ffffff;exitX=0.85;exitY=0;entryX=0.55;entryY=1;" edge="1" parent="1" source="L6" target="L7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="Lnote" value="RetailStart (consigna): ELT carga datos al data lake (raw/). ETL transforma y deja salida en el lake (processed/). load_dw carga esos datos al data warehouse (Postgres). En un Lambda de libro, Spark/Hadoop y Kafka/Flink reemplazan el batch Python; la speed layer no está implementada." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#64748b;" vertex="1" parent="1">
          <mxGeometry x="40" y="605" width="1700" height="48" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
