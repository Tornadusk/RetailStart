        <mxCell id="LTITLE" value="&lt;font style=&quot;font-size: 18px&quot;&gt;&lt;b style=&quot;color: #000000&quot;&gt;Diagrama de arquitectura lógica (modelo Lambda)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px; color: #333333&quot;&gt;Vista adaptada a RetailStart: batch implementado, speed no implementada, serving vía Docker y consumo web.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="10" width="1720" height="52" as="geometry"/>
