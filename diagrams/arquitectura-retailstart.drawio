  <diagram id="lambda-retailstart" name="1 - Lambda lógico + RetailStart">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1780" pageHeight="760" math="0" shadow="0">
